# .env.example — CloudBoard Environment Variables
# ================================================
# Copy this file to ".env" to customize your CloudBoard deployment:
#
#   cp .env.example .env
#
# Docker Compose automatically reads ".env" from the project directory.
# Values here override the defaults in compose.yaml.
#
# TIP: Never commit a real ".env" file to version control if it contains
#      secrets (passwords, API keys, etc.).  This example file is safe
#      because it only contains non-sensitive defaults.

# ── Application Settings ──────────────────────────────────────────────────
# The name displayed in the UI header and page title
APP_NAME=CloudBoard

# The greeting shown on the home page hero section
APP_GREETING=Welcome to the Docker Compose Workshop!

# ── Redis Settings ────────────────────────────────────────────────────────
# The hostname of the Redis container.
# IMPORTANT: When running with Docker Compose, this MUST match the service
# name in compose.yaml (default: "redis").  Docker resolves it via DNS.
REDIS_HOST=redis
REDIS_PORT=6379

# ── Flask Settings ────────────────────────────────────────────────────────
# The port Flask listens on inside the container, and the host port mapping.
FLASK_PORT=5000

# Set to "1" to enable Flask debug mode (auto-reload, detailed errors).
# Leave as "0" in any shared or production environment.
FLASK_DEBUG=0
